# WhatsApp AI Agent Configuration
# Copy this file to .env and fill in your values

# Google Gemini API Key (Get free at https://makersuite.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Admin WhatsApp Number (Format: countrycode+number, e.g., 919111514980)
ADMIN_NUMBER=919111514980

# Server Port
PORT=3000

# Database Path (relative or absolute)
DB_PATH=./database.db

# Node Environment
NODE_ENV=production

# Optional: Custom Database Connection
# If you have your own database, configure these:
# CUSTOM_DB_HOST=localhost
# CUSTOM_DB_USER=root
# CUSTOM_DB_PASSWORD=password
# CUSTOM_DB_NAME=your_database
